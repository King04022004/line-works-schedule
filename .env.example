PORT=3000
TZ=Asia/Tokyo
DEFAULT_RESULT_LIMIT=5
MIN_LEAD_MINUTES=30

# true: use mock data / false: use LINE WORKS API
LW_USE_MOCK=true

# LINE WORKS API
LW_API_BASE_URL=https://www.worksapis.com/v1.0
LW_AUTH_TOKEN_URL=https://auth.worksmobile.com/oauth2/v2.0/token
LW_CLIENT_ID=
LW_CLIENT_SECRET=
LW_SERVICE_ACCOUNT=
LW_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback
LW_OAUTH_SCOPES=calendar calendar.read directory directory.read
LW_BOT_FIXED_MENU_PATH_TEMPLATE=

# Choose one:
# 1) put full key string (single line, include BEGIN/END and \n escapes)
LW_PRIVATE_KEY=
# 2) or point to a local key file path (.pem / .txt)
LW_PRIVATE_KEY_PATH=

# Optional path templates
LW_CALENDAR_BUSY_PATH_TEMPLATE=/users/{userId}/calendar/events?fromDateTime={from}&untilDateTime={to}
LW_CALENDAR_CREATE_PATH_TEMPLATE=/users/{calendarId}/calendar/events
